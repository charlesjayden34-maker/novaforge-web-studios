PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/novaforge
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173
ALLOW_DEV_RESET_TOKEN_RESPONSE=false

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
ADMIN_NOTIFY_EMAIL=admin@example.com
FROM_EMAIL="NovaForge Web Studios <no-reply@novaforge.dev>"
CAMPAIGN_REPLY_TO=nathanwhittaker141@gmail.com
PUBLIC_SITE_URL=https://novaforge-web-studios.com
CAMPAIGN_WAIT_DAYS=5
CAMPAIGN_DAILY_LIMIT=30
CAMPAIGN_POPULAR_HOURS_ONLY=true
CAMPAIGN_DEFAULT_TIMEZONE=America/Barbados

# IMAP reply detection (optional, for auto-stop follow-ups on replies)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your_email@example.com
IMAP_PASS=your_app_password
IMAP_MAILBOX=INBOX
IMAP_LOOKBACK_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# First admin (optional — use npm run seed-admin)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change_me_strong
ADMIN_NAME=Admin

