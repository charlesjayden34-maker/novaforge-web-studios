PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/orvanta
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
TRUST_PROXY=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173
# Keep false in production. Only enable for local SMTP-free testing.
ALLOW_DEV_RESET_TOKEN_RESPONSE=false

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
ADMIN_NOTIFY_EMAIL=admin@example.com
FROM_EMAIL="Orvanta Studio <no-reply@orvanta.dev>"
CAMPAIGN_REPLY_TO=owner@example.com
CAMPAIGN_UNSUBSCRIBE_EMAIL=owner@example.com
PUBLIC_SITE_URL=https://your-frontend-domain.com
CAMPAIGN_WAIT_DAYS=5
CAMPAIGN_DAILY_LIMIT=30
CAMPAIGN_MAX_SENDS_PER_CONTACT=2
CAMPAIGN_DELAY_JITTER_MS=1200
CAMPAIGN_ALLOW_ROLE_ADDRESSES=false
CAMPAIGN_REQUIRE_OWNER_NAME=false
CAMPAIGN_POPULAR_HOURS_ONLY=true
CAMPAIGN_DEFAULT_TIMEZONE=America/Barbados
CAMPAIGN_DKIM_SELECTOR=default
CAMPAIGN_SENDER_NAME=Nathan Whittaker
CAMPAIGN_SENDER_ROLE=Business Partner
CAMPAIGN_SENDER_COMPANY=Orvanta Studio
CAMPAIGN_SENDER_EMAIL=nathanwhittaker141@gmail.com
CAMPAIGN_DEFAULT_CTA=If you are open to it, I can share a quick 1-page website plan tailored to your business.

# IMAP reply detection (optional, for auto-stop follow-ups on replies)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your_email@example.com
IMAP_PASS=your_app_password
IMAP_MAILBOX=INBOX
IMAP_LOOKBACK_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# First admin (optional — use npm run seed-admin)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change_me_strong
ADMIN_NAME=Admin

